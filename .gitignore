# Whitelist model — everything is ignored by default.
# To track a new file type, add a `!`-line below. Do not flip to blacklist.

*

# Re-allow tracked paths
!.gitignore
!.gitmodules
!.github/
!.github/**
!README.md
!flightrecorder/
!flightrecorder/**
!scripts/
!scripts/**
!src/
!src/**

# Hugo build output
src/public/
src/resources/
src/.hugo_build.lock

# Never track
.venv/
node_modules/
target/
dist/
build/
__pycache__/
*.pyc
.DS_Store
artifacts/
