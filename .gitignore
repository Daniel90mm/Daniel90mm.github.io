# Whitelist model — everything is ignored by default.
# To track a new file type, add a `!`-line below. Do not flip to blacklist.

*

# Re-allow tracked paths
!.gitignore
!.gitmodules
!.github/
!.github/**
!AGENTS.md
!CLAUDE.md
!README.md
!flightrecorder/
!flightrecorder/**
!scripts/
!scripts/**
!museum/
!museum/**

# Hugo build output
museum/public/
museum/resources/
museum/.hugo_build.lock

# Never track
.venv/
node_modules/
target/
dist/
build/
__pycache__/
*.pyc
.DS_Store
artifacts/
.agent-delegation/
.agent-tasks/
flightrecorder/.env*
flightrecorder/config*.local.toml
flightrecorder/pricing*.local.toml
flightrecorder/scripts/*local*.sh
