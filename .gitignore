# Whitelist model — everything is ignored by default.
# To track a new file type, add a `!`-line below. Do not flip to blacklist.

*

# Re-allow tracked paths
!.gitignore
!.githooks/
!.githooks/**
!README.md
!CLAUDE.md
!AGENTS.md
!IDEAS_TRAIL.md
!RESEARCH_LOG.md
!DESIGN_PRINCIPLES.md
!pyproject.toml
!package.json
!Cargo.toml
!docs/
!docs/**
!scripts/
!scripts/**
!src/
!src/**
!.github/
!.github/**
!.gitmodules
!tests/
!tests/**

# Hugo build output
src/public/
src/resources/
src/.hugo_build.lock
!handoffs/
!handoffs/**
!consults/
!consults/**

# Never track
.venv/
node_modules/
target/
dist/
build/
__pycache__/
*.pyc
.DS_Store
artifacts/
